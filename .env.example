# =========================================
# LoyaPing — Environment Variables
# Copy to .env.local and fill in your values
# =========================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# App URL (used in magic links and OAuth callbacks)
# In production: https://your-app.vercel.app (or your custom domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Default business ID (seeded in migration 001)
DEFAULT_BUSINESS_ID=00000000-0000-0000-0000-000000000001

# WhatsApp Provider: "cloud_api" | "twilio" | "mock"
WHATSAPP_PROVIDER=mock

# Meta WhatsApp Cloud API (required if WHATSAPP_PROVIDER=cloud_api)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=my-verify-token-secret

# Twilio (required if WHATSAPP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Cron job protection secret (generate a random string)
CRON_SECRET=change-me-in-production

# Google Calendar integration (optional)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Microsoft / Outlook Calendar integration (optional)
MICROSOFT_CALENDAR_CLIENT_ID=
MICROSOFT_CALENDAR_CLIENT_SECRET=
MICROSOFT_CALENDAR_TENANT_ID=common
